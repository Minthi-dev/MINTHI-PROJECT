# Supabase - copia questo file in .env e inserisci i valori reali
# Trovali su: https://app.supabase.com > Project Settings > API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# URL di produzione dell'app (usata per generare QR code corretti dall'app nativa iOS)
# Su web (Vercel) non serve, window.location.origin funziona automaticamente
VITE_APP_URL=https://minthi.it
